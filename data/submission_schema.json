{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SCPC Final Round Submission",
  "type": "object",
  "required": ["schema", "answers"],
  "properties": {
    "schema": { "const": "scpc.final.answer.v1" },
    "meta": {
      "type": "object",
      "additionalProperties": true
    },
    "answers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["focal_id", "target", "control", "content_scope", "policy", "plan_events"],
        "properties": {
          "focal_id": { "type": "string" },
          "target": { "type": "string" },
          "control": { "enum": ["proceed", "amend", "hold", "ask"] },
          "content_scope": {
            "type": "object",
            "required": ["mode", "allowed_fields", "excluded_fields", "requires_user_confirmation"],
            "properties": {
              "mode": { "enum": ["raw", "summary", "redacted", "status_only", "none"] },
              "allowed_fields": { "type": "array", "items": { "type": "string" } },
              "excluded_fields": { "type": "array", "items": { "type": "string" } },
              "requires_user_confirmation": { "type": "boolean" }
            },
            "additionalProperties": true
          },
          "policy": {
            "type": "object",
            "required": ["risk_flags", "violations", "requires_confirmation"],
            "properties": {
              "risk_flags": { "type": "array", "items": { "type": "string" } },
              "violations": { "type": "array", "items": { "type": "string" } },
              "requires_confirmation": { "type": "boolean" }
            },
            "additionalProperties": true
          },
          "plan_events": {
            "type": "array",
            "maxItems": 18,
            "items": {
              "type": "object",
              "required": ["verb", "target", "args"],
              "properties": {
                "verb": { "type": "string" },
                "target": { "type": "string" },
                "args": { "type": "object" }
              },
              "additionalProperties": true
            }
          },
          "user_response": { "type": "string" },
          "audit_tags": { "type": "array", "items": { "type": "string" } },
          "counterfactual": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
